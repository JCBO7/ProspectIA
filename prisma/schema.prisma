generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  plan          Plan        @default(FREE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  accounts      Account[]
  sessions      Session[]
  workspaces    Workspace[]
}

model Workspace {
  id                  String      @id @default(cuid())
  userId              String
  name                String
  businessDescription String?
  industry            String?
  location            String?
  website             String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  campanas            Campana[]
  mensajes            Mensaje[]
  prospectos          Prospecto[]
  plantillas          Plantilla[]
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Plantilla {
  id          String   @id @default(cuid())
  workspaceId String
  nombre      String
  canal       Canal
  contenido   String
  asunto      String?
  descripcion String?
  usosCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Prospecto {
  id                String             @id @default(cuid())
  workspaceId       String
  empresa           String
  giro              String?
  giroSCIAN         String?
  zona              String?
  alcaldia          String?
  ciudad            String             @default("Ciudad de México")
  tamano            TamanoEmpresa?
  contacto          String?
  cargo             String?
  telefono          String?
  email             String?
  website           String?
  direccion         String?
  score             Int                @default(0)
  status            ProspectoStatus    @default(NUEVO)
  fuente            FuenteProspecto    @default(MANUAL)
  notas             String?
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  campanaProspectos CampanaProspecto[]
  mensajes          Mensaje[]
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Campana {
  id          String             @id @default(cuid())
  workspaceId String
  nombre      String
  descripcion String?
  canal       Canal
  mensaje     String
  asunto      String?
  status      CampanaStatus      @default(BORRADOR)
  scheduledAt DateTime?
  lanzadaAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospectos  CampanaProspecto[]
}

model CampanaProspecto {
  id          String      @id @default(cuid())
  campanaId   String
  prospectoId String
  status      EnvioStatus @default(PENDIENTE)
  enviadoAt   DateTime?
  respondioAt DateTime?
  notas       String?
  metadata    Json?
  createdAt   DateTime    @default(now())
  campana     Campana     @relation(fields: [campanaId], references: [id], onDelete: Cascade)
  prospecto   Prospecto   @relation(fields: [prospectoId], references: [id], onDelete: Cascade)

  @@unique([campanaId, prospectoId])
}

model Mensaje {
  id          String     @id @default(cuid())
  workspaceId String
  prospectoId String?
  canal       Canal
  contenido   String
  asunto      String?
  generadoPor String     @default("IA")
  enviado     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  prospecto   Prospecto? @relation(fields: [prospectoId], references: [id])
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum TamanoEmpresa {
  MICRO
  PEQUENA
  MEDIANA
  GRANDE
}

enum ProspectoStatus {
  NUEVO
  CONTACTADO
  INTERESADO
  NO_INTERESADO
  CONVERTIDO
  DESCARTADO
}

enum FuenteProspecto {
  DENUE
  GOOGLE_MAPS
  SECCION_AMARILLA
  MANUAL
  IMPORTADO
}

enum Canal {
  WHATSAPP
  EMAIL
  SMS
  LINKEDIN
  FACEBOOK
  INSTAGRAM
  LLAMADA
}

enum CampanaStatus {
  BORRADOR
  PROGRAMADA
  EN_CURSO
  PAUSADA
  COMPLETADA
  CANCELADA
}

enum EnvioStatus {
  PENDIENTE
  ENVIADO
  ENTREGADO
  LEIDO
  RESPONDIO
  ERROR
  OMITIDO
}
