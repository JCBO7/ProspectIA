# ─── Base de datos ─────────────────────────────────────────────────────────────
# Neon.tech PostgreSQL — https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Genera el secret con: openssl rand -base64 32
NEXTAUTH_URL="https://tudominio.vercel.app"
NEXTAUTH_SECRET="cambia-esto-por-un-secret-seguro"

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── Email — SMTP Brevo (300 correos/día gratis) ───────────────────────────────
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# ─── Email — Resend (opcional, fallback) ───────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="ProspectAI <noreply@tudominio.com>"

# ─── SMS — Twilio (opcional) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
TWILIO_SMS_NUMBER=""

# ─── SMS — TextBelt (gratis: 1/día) ────────────────────────────────────────────
TEXTBELT_KEY=""

# ─── Google Places API ─────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=""

# ─── Hunter.io (enriquecimiento de emails) ─────────────────────────────────────
HUNTER_API_KEY=""

# ─── DENUE INEGI API ───────────────────────────────────────────────────────────
DENUE_API_KEY=""

# ─── SIEM Secretaría de Economía (pendiente registro oficial) ──────────────────
SIEM_API_KEY=""

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://tudominio.vercel.app"
